{
  "name": "appvault-apk-directory",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js",
    "db:migrate": "node server/db/migrate.js",
    "db:seed": "node server/db/seed.js",
    "prod:check": "npm run build && npm audit --audit-level=low"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "lucide-react": "^0.562.0",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {}
}
